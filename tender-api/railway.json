{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
          "builder": "NIXPACKS",
          "watchPatterns": ["tender-api/**"]
    },
    "deploy": {
          "startCommand": "cd tender-api && uvicorn main:app --host 0.0.0.0 --port $PORT",
          "restartPolicyType": "ON_FAILURE",
          "restartPolicyMaxRetries": 3
    }
}
